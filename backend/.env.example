# 技术设计文档 12.1 + P2 本地开发配置（与 docker-compose.dev.yml 对齐）
# 复制：cp .env.example .env

KG_DATABASE_URL=postgresql+asyncpg://kg:kg@localhost:5433/kg
KG_REDIS_URL=redis://localhost:6379/0
KG_VIKING_BASE_URL=http://localhost:1933
KG_VIKING_API_KEY=dev-local-root-key
KG_VIKING_TIMEOUT_MS=800

# 本地联调登录（./scripts/dev.sh 默认开启；生产严禁）
KG_DEV_LOGIN_ENABLED=1

# 飞书自建应用（OAuth + P2 同步/事件；权限见 doc/local-dev-p2.md）
KG_LARK_APP_ID=
KG_LARK_APP_SECRET=
KG_LARK_ENCRYPT_KEY=
KG_LARK_VERIFICATION_TOKEN=

KG_SESSION_TTL_HOURS=12
KG_DEFAULT_TOP_K=5
KG_MAX_TOP_K=20
KG_UPLOAD_MAX_MB=2
KG_AUDIT_RETENTION_DAYS=180

# RocketMQ（本地 broker autoCreateTopicEnable=true）
KG_ROCKETMQ_NAMESRV=localhost:9876
KG_ROCKETMQ_TOPIC_PIPELINE=kg.pipeline
KG_ROCKETMQ_TOPIC_FEISHU_EVENT=kg.feishu.event
KG_ROCKETMQ_TOPIC_REVIEW_CARD=kg.review.card

# MinIO 作 OSS 替身（账号与 docker-compose.dev.yml 一致）
KG_OSS_ENDPOINT=http://localhost:9000
KG_OSS_ACCESS_KEY=kgminio
KG_OSS_SECRET_KEY=kgminio123
KG_OSS_BUCKET=kg-assets
KG_OSS_REGION=us-east-1
KG_OSS_PUBLIC_BASE_URL=http://localhost:9000/kg-assets

# 飞书同步轮询兜底间隔（秒）
KG_FEISHU_POLL_INTERVAL_SEC=300

# 飞书授权轮询（awaiting_auth / permission_revoked）
KG_FEISHU_AUTH_POLL_INTERVAL_SEC=60
KG_FEISHU_AUTH_TIMEOUT_HOURS=24
KG_FEISHU_ARCHIVED_RETENTION_DAYS=30
KG_FEISHU_MQ_BACKEND=memory
KG_ROCKETMQ_TOPIC_FEISHU_EVENT_DLQ=kg.feishu.event.dlq
KG_ROCKETMQ_CONSUMER_GROUP_FEISHU=kg_feishu_consumer
