# 技术设计文档 12.1 环境变量清单
KG_DATABASE_URL=postgresql+asyncpg://kg:kg@localhost:5433/kg
KG_REDIS_URL=redis://localhost:6379/0
KG_VIKING_BASE_URL=http://localhost:1933
KG_VIKING_API_KEY=dev-local-root-key
KG_VIKING_TIMEOUT_MS=800

# 飞书自建应用（控制台 OAuth；P2 另需 wiki/drive/docs 读权限与事件订阅，见 doc/local-dev-p2.md）
KG_LARK_APP_ID=
KG_LARK_APP_SECRET=

KG_SESSION_TTL_HOURS=12
KG_DEFAULT_TOP_K=5
KG_MAX_TOP_K=20
KG_UPLOAD_MAX_MB=2
KG_AUDIT_RETENTION_DAYS=180

# P2 本地基建（docker compose 默认；backend 进程 P2 联调前可不填）
KG_ROCKETMQ_NAMESRV=localhost:9876
KG_ROCKETMQ_TOPIC_PIPELINE=kg.pipeline
KG_ROCKETMQ_TOPIC_FEISHU_EVENT=kg.feishu.event
KG_ROCKETMQ_TOPIC_REVIEW_CARD=kg.review.card

# MinIO 作 OSS 替身（飞书图片转存）
KG_OSS_ENDPOINT=http://localhost:9000
KG_OSS_ACCESS_KEY=kgminio
KG_OSS_SECRET_KEY=kgminio123
KG_OSS_BUCKET=kg-assets
KG_OSS_REGION=us-east-1
